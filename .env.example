# Air Hockey configuration
#
# Copy this file to .env and edit as needed. .env is gitignored.
# Shell / CLI environment variables always override values set here.

# --- Server binding -------------------------------------------------------

# Interface the Node WebSocket server listens on.
# 0.0.0.0 = all interfaces (LAN-accessible). 127.0.0.1 = loopback only.
SERVER_HOST=0.0.0.0

# Port the Node WebSocket server listens on. Must also be what vite's
# /ws proxy targets, so changing this affects both dev server and proxy.
SERVER_PORT=8443

# --- Client WebSocket target (browser-side) -------------------------------
#
# Variables prefixed with VITE_ are exposed to browser code via
# import.meta.env at build time.
#
# Leave both blank to use same-origin with the /ws path. In dev that
# routes through vite's proxy to the server above. In production it
# assumes the server is reachable on the same origin as the static client.
#
# Set one or both to dial a different host/port directly (bypasses the
# vite proxy even in dev).

VITE_WS_HOST=
VITE_WS_PORT=
